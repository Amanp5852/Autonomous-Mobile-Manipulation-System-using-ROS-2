<launch>
    <node pkg="my_py_pkg" exec="number_publisher" name ="my_number_publisher" namespace="/abc">
        <remap from="number" to = "my_number" />
        <!-- param name="number" value="6" />
        <param name="timer_period" value="1.5" /> -->
        <param from="$(find-pkg-share my_robot_bringup)/config/number_app.yaml" />
    </node>
    <node pkg="my_py_pkg" exec="number_subscriber" name = "my_number_subscriber" >
        <remap from="/number" to = "/my_number" />
        <remap from="/number_count" to = "/my_number_count" />
    </node>

</launch>
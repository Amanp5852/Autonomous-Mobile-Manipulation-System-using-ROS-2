<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

    <xacro:property name="arm_base_length" value="0.1" />
    <xacro:property name="arm_base_width" value="0.1" />
    <xacro:property name="arm_base_height" value="0.02" />
    <xacro:property name="forearm_radius" value="0.02" />
    <xacro:property name="forearm_length" value="0.3" />
    <xacro:property name="hand_radius" value="0.02" />
    <xacro:property name="hand_length" value="0.3" />
    <xacro:property name="gripper_arm_radius" value="0.02" />
    <xacro:property name="gripper_arm_length" value="0.2" />
    <xacro:property name="gripper_base_length" value="0.25" />
    <xacro:property name="gripper_base_width" value="0.2" />
    <xacro:property name="gripper_base_height" value="0.02" />
    <xacro:property name="finger_length" value="0.15" />
    <xacro:property name="finger_width" value="0.1" />
    <xacro:property name="finger_height" value="0.02" />

    <link name="arm_base_link">
        <visual>
            <geometry>
                <box size="${arm_base_length} ${arm_base_width} ${arm_base_height}" />
            </geometry>
            <origin xyz="0 0 ${arm_base_height / 2.0}" rpy="0 0 0" />
            <material name="orange" />
        </visual>
        <collision>
            <geometry>
                <box size="${arm_base_length} ${arm_base_width} ${arm_base_height}" />
            </geometry>
            <origin xyz="0 0 ${arm_base_height / 2.0}" rpy="0 0 0" />
        </collision>
        <xacro:box_inertia m="0.5" x="${arm_base_length}" y="${arm_base_width}" z="${arm_base_height}"
                           o_xyz="0 0 ${arm_base_height / 2.0}" o_rpy="0 0 0" />
    </link>

    <link name="forearm_link">
        <visual>
            <geometry>
                <cylinder radius="${forearm_radius}" length="${forearm_length}" />
            </geometry>
            <origin xyz="0 0 ${forearm_length / 2.0}" rpy="0 0 0" />
            <material name="yellow" />
        </visual>
        <collision>
            <geometry>
                <cylinder radius="${forearm_radius}" length="${forearm_length}" />
            </geometry>
            <origin xyz="0 0 ${forearm_length / 2.0}" rpy="0 0 0" />
        </collision>
        <xacro:cylinder_inertia m="0.3" r="${forearm_radius}" l="${forearm_length}"
                                o_xyz="0 0 ${forearm_length / 2.0}" o_rpy="0 0 0" />
    </link>

    <link name="hand_link">
        <visual>
            <geometry>
                <cylinder radius="${hand_radius}" length="${hand_length}" />
            </geometry>
            <origin xyz="0 0 ${hand_length / 2.0}" rpy="0 0 0" />
            <material name="orange" />
        </visual>
        <collision>
            <geometry>
                <cylinder radius="${hand_radius}" length="${hand_length}" />
            </geometry>
            <origin xyz="0 0 ${hand_length / 2.0}" rpy="0 0 0" />
        </collision>
        <xacro:cylinder_inertia m="0.3" r="${hand_radius}" l="${hand_length}"
                                o_xyz="0 0 ${hand_length / 2.0}" o_rpy="0 0 0" />
    </link>

    <link name="gripper_arm_link">
        <visual>
            <geometry>
                <cylinder radius="${gripper_arm_radius}" length="${gripper_arm_length}" />
            </geometry>
            <origin xyz="${gripper_arm_length / 2.0} 0 0" rpy="0 ${pi / 2.0} 0" />
            <material name="blue" />
        </visual>
        <collision>
            <geometry>
                <cylinder radius="${gripper_arm_radius}" length="${gripper_arm_length}" />
            </geometry>
            <origin xyz="${gripper_arm_length / 2.0} 0 0" rpy="0 ${pi / 2.0} 0" />
        </collision>
        <xacro:cylinder_inertia m="0.15" r="${gripper_arm_radius}" l="${gripper_arm_length}"
                                o_xyz="${gripper_arm_length / 2.0} 0 0" o_rpy="0 ${pi / 2.0} 0" />
    </link>

    <link name="gripper_base_link">
        <visual>
            <geometry>
                <box size="${gripper_base_length} ${gripper_base_width} ${gripper_base_height}" />
            </geometry>
            <origin xyz="${gripper_base_length / 2.0} 0 ${- gripper_base_height / 2.0}" rpy="0 0 0" />
            <material name="grey" />
        </visual>
        <collision>
            <geometry>
                <box size="${gripper_base_length} ${gripper_base_width} ${gripper_base_height}" />
            </geometry>
            <origin xyz="${gripper_base_length / 2.0} 0 ${- gripper_base_height / 2.0}" rpy="0 0 0" />
        </collision>
        <xacro:box_inertia m="0.25" x="${gripper_base_length}" y="${gripper_base_width}" z="${gripper_base_height}"
                           o_xyz="${gripper_base_length / 2.0} 0 ${- gripper_base_height / 2.0}" o_rpy="0 0 0" />
    </link>

    <link name="finger_right_link">
        <visual>
            <geometry>
                <box size="${finger_length} ${finger_width} ${finger_height}" />
            </geometry>
            <origin xyz="0 0 ${- finger_width / 2.0}" rpy="${pi / 2.0} 0 0" />
            <material name="blue" />
        </visual>
        <collision>
            <geometry>
                <box size="${finger_length} ${finger_width} ${finger_height}" />
            </geometry>
            <origin xyz="0 0 ${- finger_width / 2.0}" rpy="${pi / 2.0} 0 0" />
        </collision>
        <xacro:box_inertia m="0.08" x="${finger_length}" y="${finger_width}" z="${finger_height}"
                           o_xyz="0 0 ${- finger_width / 2.0}" o_rpy="${pi / 2.0} 0 0" />
    </link>

    <link name="finger_left_link">
        <visual>
            <geometry>
                <box size="${finger_length} ${finger_width} ${finger_height}" />
            </geometry>
            <origin xyz="0 0 ${- finger_width / 2.0}" rpy="${pi / 2.0} 0 0" />
            <material name="blue" />
        </visual>
        <collision>
            <geometry>
                <box size="${finger_length} ${finger_width} ${finger_height}" />
            </geometry>
            <origin xyz="0 0 ${- finger_width / 2.0}" rpy="${pi / 2.0} 0 0" />
        </collision>
        <xacro:box_inertia m="0.08" x="${finger_length}" y="${finger_width}" z="${finger_height}"
                           o_xyz="0 0 ${- finger_width / 2.0}" o_rpy="${pi / 2.0} 0 0" />
    </link>

    <joint name="arm_base_forearm_joint" type="revolute">
        <parent link="arm_base_link" />
        <child link="forearm_link" />
        <origin xyz="0 0 ${arm_base_height}" rpy="0 0 0" />
        <axis xyz="0 1 0" />
        <limit lower="${- pi/2}" upper="${pi/2}" effort="100" velocity="100" />
        <dynamics friction="1.0" damping="5.0" />
    </joint>

    <joint name="forearm_hand_joint" type="revolute">
        <parent link="forearm_link" />
        <child link="hand_link" />
        <origin xyz="0 0 ${forearm_length}" rpy="0 0 0" />
        <axis xyz="0 1 0" />
        <limit lower="${- pi/2}" upper="${pi/2}" effort="100" velocity="100" />
        <dynamics friction="1.0" damping="5.0" />
    </joint>

    <joint name="hand_gripper_arm_joint" type="revolute">
        <parent link="hand_link" />
        <child link="gripper_arm_link" />
        <origin xyz="0 0 ${hand_length}" rpy="0 0 0" />
        <axis xyz="0 1 0" />
        <limit lower="${- pi/2}" upper="${pi/2}" effort="100" velocity="100" />
        <dynamics friction="1.0" damping="3.0" />
    </joint>

    <joint name="gripper_arm_base_joint" type="revolute">
        <parent link="gripper_arm_link" />
        <child link="gripper_base_link" />
        <origin xyz="${gripper_arm_length} 0 0" rpy="0 0 0" />
        <axis xyz="0 1 0" />
        <limit lower="${- pi/2}" upper="${pi/2}" effort="100" velocity="100" />
        <dynamics friction="1.0" damping="3.0" />
    </joint>

    <joint name="gripper_base_finger_right_joint" type="prismatic">
        <parent link="gripper_base_link" />
        <child link="finger_right_link" />
        <origin xyz="${gripper_base_length / 2.0} 0.0875 ${- gripper_arm_radius / 2.0 - gripper_base_height / 2.0}" rpy="0 0 0" />
        <axis xyz="0 -1 0" />
        <limit lower="0" upper="0.04" effort="100" velocity="100" />
        <dynamics friction="1.0" damping="5.0" />
    </joint>

    <joint name="gripper_base_finger_left_joint" type="prismatic">
        <parent link="gripper_base_link" />
        <child link="finger_left_link" />
        <origin xyz="${gripper_base_length / 2.0} -0.0875 ${- gripper_arm_radius / 2.0 - gripper_base_height / 2.0}" rpy="0 0 0" />
        <axis xyz="0 1 0" />
        <limit lower="0" upper="0.04" effort="100" velocity="100" />
        <dynamics friction="1.0" damping="5.0" />
    </joint>

</robot>